<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1E4620">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Data, hora e status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/txtData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="#B0BEC5"/>

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                app:backgroundTint="#0D47A1"/>

        </LinearLayout>

        <!-- Times e placar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <!-- Time Mandante -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imgMandante"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:layout_marginBottom="6dp"
                    android:contentDescription="Time mandante"/>

                <TextView
                    android:id="@+id/txtMandante"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:maxLines="2"/>

            </LinearLayout>

            <!-- Placar / VS -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtPlacar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- Time Visitante -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imgVisitante"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:layout_marginBottom="6dp"
                    android:contentDescription="Time visitante"/>

                <TextView
                    android:id="@+id/txtVisitante"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:maxLines="2"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Botões de gol (só Em Andamento) -->
        <LinearLayout
            android:id="@+id/layoutBotoesGol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnMenosMandante"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="−"
                android:textSize="18sp"
                android:padding="0dp"
                android:backgroundTint="#2E7D32"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <Button
                android:id="@+id/btnMaisMandante"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="18sp"
                android:padding="0dp"
                android:layout_marginStart="4dp"
                android:backgroundTint="#2E7D32"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnMenosVisitante"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="−"
                android:textSize="18sp"
                android:padding="0dp"
                android:backgroundTint="#2E7D32"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <Button
                android:id="@+id/btnMaisVisitante"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="18sp"
                android:padding="0dp"
                android:layout_marginStart="4dp"
                android:backgroundTint="#2E7D32"/>

        </LinearLayout>

        <!-- Botão Iniciar -->
        <Button
            android:id="@+id/btnIniciar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Iniciar Jogo"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0D47A1"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <!-- Botões Intervalo e Finalizar -->
        <LinearLayout
            android:id="@+id/layoutBotoesControle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnIntervalo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Intervalo"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FFB300"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnFinalizar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Finalizar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- Editar / Deletar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnApostar"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="🎯 Apostar"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0D47A1"
                android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/btnEditarJogo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="#B0BEC5"
                android:contentDescription="Editar"/>

            <ImageButton
                android:id="@+id/btnDeletarJogo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#E57373"
                android:contentDescription="Remover"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>